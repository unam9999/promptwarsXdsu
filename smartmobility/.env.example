# SafeRoute AI — Environment Variables
# Copy this file to .env and fill in your keys

# Google Maps JavaScript API key (sent to client for map rendering)
# Restrict by HTTP referrer in Google Cloud Console
GOOGLE_MAPS_API_KEY=your-maps-api-key-here

# Gemini API key (server-side only, never exposed to browser)
# Restrict by IP in Google Cloud Console
GEMINI_API_KEY=your-gemini-api-key-here

# Server port (Cloud Run uses 8080)
PORT=8080
